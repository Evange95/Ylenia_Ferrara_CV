# Static assets — long cache with immutable
/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/*.webp
  Cache-Control: public, max-age=31536000, immutable

/*.svg
  Cache-Control: public, max-age=31536000, immutable

/*.pdf
  Cache-Control: public, max-age=86400

# Sitemap and robots
/robots.txt
  Cache-Control: public, max-age=86400

/sitemap-*.xml
  Cache-Control: public, max-age=86400
