---
import { t, type Lang } from '../i18n/index.ts';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const tr = t(lang);
const base = import.meta.env.BASE_URL;
const altHref = lang === 'en' ? `${base}it/` : base;

const links = [
  { href: '#about',      label: tr.nav.about },
  { href: '#experience', label: tr.nav.experience },
  { href: '#skills',     label: tr.nav.skills },
  { href: '#projects',   label: tr.nav.projects },
  { href: '#writing',    label: tr.nav.writing },
  { href: '#contact',    label: tr.nav.contact },
];
---
<nav id="nav">
  <div class="nav-inner container">
    <a class="nav-logo" href="#hero">YF</a>
    <ul class="nav-links">
      {links.map(l => <li><a href={l.href}>{l.label}</a></li>)}
    </ul>
    <a class="lang-switch" href={altHref}>{tr.nav.switchLabel}</a>
    <a class="btn btn-primary nav-cta" href={`${base}${tr.cvFile}`} download>{tr.nav.download}</a>
    <button class="nav-burger" aria-label="Menu" onclick="this.closest('nav').classList.toggle('open')">
      <span></span><span></span><span></span>
    </button>
  </div>
  <div class="nav-drawer">
    <ul>
      {links.map(l => (
        <li>
          <a href={l.href} onclick="document.getElementById('nav').classList.remove('open')">{l.label}</a>
        </li>
      ))}
    </ul>
    <a class="lang-switch-drawer" href={altHref}>{tr.nav.switchLabel}</a>
  </div>
</nav>

<style>
nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  transition: background 0.3s, box-shadow 0.3s;
}

.nav-inner {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  padding-top: 1rem;
  padding-bottom: 1rem;
}

.nav-logo {
  font-family: var(--font-display);
  font-size: 1.4rem;
  font-weight: 700;
  color: var(--violet);
  letter-spacing: -0.02em;
  margin-right: auto;
}

.nav-links {
  display: flex;
  list-style: none;
  gap: 1.5rem;
}

.nav-links a {
  font-size: 0.88rem;
  font-weight: 500;
  color: var(--body);
  transition: color 0.2s;
}
.nav-links a:hover { color: var(--violet); }

.lang-switch {
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  color: var(--muted);
  border: 1px solid var(--border);
  border-radius: 1rem;
  padding: 0.3rem 0.65rem;
  transition: color 0.2s, border-color 0.2s;
  flex-shrink: 0;
}
.lang-switch:hover { color: var(--violet); border-color: var(--violet); }

.nav-cta { font-size: 0.85rem; padding: 0.55rem 1.25rem; flex-shrink: 0; }

.nav-burger {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
}
.nav-burger span {
  display: block;
  width: 22px;
  height: 2px;
  background: var(--dark);
  border-radius: 2px;
}

.nav-drawer {
  display: none;
  background: var(--white);
  border-top: 1px solid var(--border);
  padding: 1rem 1.25rem 1.5rem;
}
.nav-drawer ul { list-style: none; }
.nav-drawer li a {
  display: block;
  padding: 0.65rem 0;
  font-size: 1rem;
  font-weight: 500;
  color: var(--dark);
  border-bottom: 1px solid var(--border);
}

.lang-switch-drawer {
  display: inline-block;
  margin-top: 1.25rem;
  font-size: 0.82rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  color: var(--violet);
  border: 1px solid var(--violet);
  border-radius: 1rem;
  padding: 0.35rem 0.85rem;
}

@media (max-width: 900px) {
  .nav-links, .nav-cta, .lang-switch { display: none; }
  .nav-burger { display: flex; }
  nav.open .nav-drawer { display: block; }
  nav.open { background: rgba(255,255,255,0.98); }
}
</style>
