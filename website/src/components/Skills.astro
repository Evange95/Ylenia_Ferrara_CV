---
import { t, type Lang } from '../i18n/index.ts';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const tr = t(lang);
const sk = tr.skills;
---
<section id="skills" class="section section-compact">
  <div class="container">
    <p class="section-label">{sk.label}</p>
    <h2 class="section-title">{sk.title}</h2>
    <div class="skills-list">
      {sk.groups.map((group: { icon: string; category: string; skills: string[] }, i: number) => (
        <div class="skill-row fade-in" style={`transition-delay:${i * 0.06}s`}>
          <div class="skill-heading">
            <span class="skill-icon">{group.icon}</span>
            <h3 class="skill-category">{group.category}</h3>
          </div>
          <div class="skill-tags">
            {group.skills.map((s: string) => <span class="tag">{s}</span>)}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
#skills { background: var(--surface); }

.skills-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.skill-row {
  display: flex;
  align-items: baseline;
  gap: 1.5rem;
  padding: 1.25rem 0;
  border-bottom: 1px solid var(--border);
}
.skill-row:first-child {
  border-top: 1px solid var(--border);
}

.skill-heading {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  flex-shrink: 0;
  width: 200px;
}

.skill-icon {
  font-size: 1.1rem;
  line-height: 1;
}

.skill-category {
  font-family: var(--font-body);
  font-size: 0.88rem;
  font-weight: 600;
  color: var(--dark);
  letter-spacing: 0.01em;
}

.skill-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
  flex: 1;
}

@media (max-width: 700px) {
  .skill-row {
    flex-direction: column;
    gap: 0.75rem;
    align-items: flex-start;
  }
  .skill-heading { width: auto; }
}
</style>
