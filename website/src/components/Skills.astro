---
import { t, type Lang } from '../i18n/index.ts';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const tr = t(lang);
const sk = tr.skills;
---
<section id="skills" class="section">
  <div class="container">
    <p class="section-label">{sk.label}</p>
    <h2 class="section-title">{sk.title}</h2>
    <div class="skills-grid">
      {sk.groups.map((group, i) => (
        <div class="skill-card card fade-in" style={`transition-delay:${i * 0.1}s`}>
          <div class="skill-icon">{group.icon}</div>
          <h3 class="skill-category">{group.category}</h3>
          <div class="skill-tags">
            {group.skills.map(s => <span class="tag">{s}</span>)}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
#skills { background: var(--surface); }

.skills-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.25rem;
}

.skill-card {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.skill-icon {
  font-size: 1.6rem;
  line-height: 1;
}

.skill-category {
  font-family: var(--font-display);
  font-size: 1.05rem;
  font-weight: 600;
  color: var(--dark);
}

.skill-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
}

@media (max-width: 900px) {
  .skills-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 560px) {
  .skills-grid { grid-template-columns: 1fr; }
}
</style>
