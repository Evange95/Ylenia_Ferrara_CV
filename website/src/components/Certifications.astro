---
import { t, type Lang } from '../i18n/index.ts';
import certsData from '../content/certifications.json';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const tr = t(lang);

const years = certsData.years;

const issuerColor: Record<string, string> = {
  'LinkedIn':         '#0A66C2',
  'Google':           '#4285F4',
  'Google / Coursera':'#4285F4',
  'Asana':            '#F06A6A',
  'Canva':            '#00C4CC',
  'Figma':            '#A259FF',
  'Microsoft':        '#737373',
  'LVMH':             '#C9953A',
  'Oxford International': '#8B1A1A',
  'Various':          '#7B6FA0',
};
---
<section id="certifications" class="section section-compact">
  <div class="container">
    <p class="section-label">{tr.certifications.label}</p>
    <h2 class="section-title">{tr.certifications.title}</h2>

    <div class="cert-timeline">
      {years.map((group, gi) => (
        <div class="cert-year-group fade-in" style={`transition-delay:${gi * 0.08}s`}>
          <div class="year-label">{group.year}</div>
          <div class="year-certs">
            {group.certs.map((c: { issuer: string; name: string; pdf?: string }) => (
              <div class="cert-pill">
                <span class="cert-dot" style={`background:${issuerColor[c.issuer] ?? 'var(--violet)'}`}></span>
                {c.pdf
                  ? <a class="cert-name" href={c.pdf} target="_blank" rel="noopener noreferrer">{c.name}</a>
                  : <span class="cert-name">{c.name}</span>}
                <span class="cert-issuer-label">{c.issuer}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
#certifications { background: var(--violet-pale); }

.cert-timeline {
  display: flex;
  flex-direction: column;
  gap: 2rem;
}

.cert-year-group {
  display: grid;
  grid-template-columns: 4rem 1fr;
  gap: 1.5rem;
  align-items: start;
}

.year-label {
  font-family: var(--font-display);
  font-size: 1rem;
  font-weight: 700;
  color: var(--violet);
  text-align: right;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 0.75rem;
  min-height: 2rem;
}
.year-label::after {
  content: '';
  flex-shrink: 0;
  width: 8px; height: 8px;
  border-radius: 50%;
  background: var(--violet);
  border: 2px solid var(--white);
  box-shadow: 0 0 0 2px var(--violet);
  margin-right: -1.25rem;
}

.year-certs {
  border-left: 2px solid var(--border);
  padding-left: 1.5rem;
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.cert-pill {
  display: inline-flex;
  align-items: center;
  gap: 0.45rem;
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 2rem;
  padding: 0.35rem 0.85rem;
  box-shadow: var(--shadow-sm);
}

.cert-dot {
  display: block;
  width: 8px; height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}

.cert-name {
  font-size: 0.85rem;
  font-weight: 500;
  color: var(--dark);
  text-decoration: none;
}
a.cert-name {
  border-bottom: 1px solid transparent;
  transition: border-color 0.2s, color 0.2s;
}
a.cert-name:hover {
  color: var(--violet);
  border-color: var(--violet);
}

.cert-issuer-label {
  font-size: 0.72rem;
  color: var(--muted);
  border-left: 1px solid var(--border);
  padding-left: 0.45rem;
  margin-left: 0.1rem;
}

@media (max-width: 600px) {
  .cert-year-group { grid-template-columns: 3rem 1fr; gap: 1rem; }
  .year-certs { padding-left: 1rem; }
}
</style>
