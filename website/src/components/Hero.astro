---
import { t, type Lang } from '../i18n/index.ts';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const tr = t(lang);
const base = import.meta.env.BASE_URL;
---
<section id="hero">
  <div class="container hero-inner">
    <div class="hero-text">
      <p class="hero-greeting">{tr.hero.greeting}</p>
      <h1 class="hero-name">Ylenia<br/>Ferrara</h1>
      <p class="hero-title">CSR Lead &amp; Corporate Communication Specialist<span class="hero-dot">·</span>Project Manager</p>
      <blockquote class="hero-quote">{tr.hero.quote}</blockquote>
      <div class="hero-ctas">
        <a class="btn btn-primary" href={`${base}${tr.cvFile}`} download>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          {tr.hero.download}
        </a>
      </div>
      <div class="hero-socials">
        <a href="https://www.linkedin.com/in/yleniaferrara" target="_blank" rel="noopener" aria-label="LinkedIn">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
          LinkedIn
        </a>
        <a href="https://medium.com/@yleniaferrara" target="_blank" rel="noopener" aria-label="Medium">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M13.54 12a6.8 6.8 0 0 1-6.77 6.82A6.8 6.8 0 0 1 0 12a6.8 6.8 0 0 1 6.77-6.82A6.8 6.8 0 0 1 13.54 12zm7.42 0c0 3.54-1.51 6.42-3.38 6.42-1.87 0-3.39-2.88-3.39-6.42s1.52-6.42 3.39-6.42 3.38 2.88 3.38 6.42M24 12c0 3.17-.53 5.75-1.19 5.75-.66 0-1.19-2.58-1.19-5.75s.53-5.75 1.19-5.75C23.47 6.25 24 8.83 24 12z"/></svg>
          Medium
        </a>
        <a href="mailto:yleferrara96@gmail.com" aria-label="Email">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          Email
        </a>
      </div>
    </div>

    <div class="hero-photo-wrap">
      <div class="hero-photo-ring">
        <img src={`${base}me.jpg`} alt="Ylenia Ferrara — CSR Lead and Corporate Communication Specialist based in Milan" class="hero-photo" width="320" height="320" />
      </div>
      <div class="hero-photo-bg"></div>
    </div>
  </div>

  <div class="hero-scroll-hint">
    <span>{tr.hero.scroll}</span>
    <svg width="14" height="20" viewBox="0 0 14 20" fill="none"><rect x="1" y="1" width="12" height="18" rx="6" stroke="var(--muted)" stroke-width="1.5"/><circle class="scroll-dot" cx="7" cy="6" r="2" fill="var(--violet)"/></svg>
  </div>
</section>

<style>
#hero {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  background: linear-gradient(145deg, #fff 0%, var(--violet-pale) 60%, #f0e6ff 100%);
  position: relative;
  overflow: hidden;
}

#hero::before {
  content: '';
  position: absolute;
  top: -120px; right: -120px;
  width: 500px; height: 500px;
  background: radial-gradient(circle, rgba(152,98,221,0.12) 0%, transparent 70%);
  pointer-events: none;
}

.hero-inner {
  display: grid;
  grid-template-columns: 1fr auto;
  align-items: center;
  gap: 4rem;
  padding-top: 6rem;
  padding-bottom: 4rem;
}

.hero-greeting {
  font-size: 1.1rem;
  color: var(--muted);
  font-weight: 400;
  letter-spacing: 0.02em;
  margin-bottom: 0.5rem;
}

.hero-name {
  font-size: clamp(3rem, 7vw, 5.5rem);
  font-weight: 700;
  line-height: 1.05;
  color: var(--dark);
  margin-bottom: 1rem;
  background: linear-gradient(135deg, var(--dark) 30%, var(--violet) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero-title {
  font-size: clamp(1rem, 1.8vw, 1.15rem);
  font-weight: 500;
  color: var(--body);
  margin-bottom: 1.5rem;
  line-height: 1.5;
}

.hero-dot {
  display: inline-block;
  margin: 0 0.5rem;
  color: var(--violet);
}

.hero-quote {
  font-family: var(--font-display);
  font-style: italic;
  font-size: 1rem;
  color: var(--muted);
  border-left: 3px solid var(--violet);
  padding-left: 1rem;
  margin-bottom: 2.5rem;
  max-width: 480px;
  line-height: 1.6;
}

.hero-ctas {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  margin-bottom: 2rem;
}

.hero-socials {
  display: flex;
  gap: 1.25rem;
  flex-wrap: wrap;
}

.hero-socials a {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.85rem;
  font-weight: 500;
  color: var(--muted);
  transition: color 0.2s;
}
.hero-socials a:hover { color: var(--violet); }

/* Photo */
.hero-photo-wrap {
  position: relative;
  width: 320px;
  height: 320px;
  flex-shrink: 0;
}

.hero-photo-bg {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--violet-light), var(--violet));
  transform: translate(12px, 12px);
  z-index: 0;
}

.hero-photo-ring {
  position: relative;
  z-index: 1;
  width: 320px;
  height: 320px;
  border-radius: 50%;
  overflow: hidden;
  border: 4px solid var(--white);
  box-shadow: var(--shadow-lg);
}

.hero-photo {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
}

/* Scroll hint */
.hero-scroll-hint {
  position: absolute;
  bottom: 2rem;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  color: var(--muted);
  font-size: 0.72rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.scroll-dot {
  animation: scrollBounce 1.8s ease-in-out infinite;
}
@keyframes scrollBounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(6px); }
}

@media (max-width: 900px) {
  .hero-inner {
    grid-template-columns: 1fr;
    text-align: center;
    gap: 2.5rem;
  }
  .hero-quote { margin-left: auto; margin-right: auto; }
  .hero-ctas, .hero-socials { justify-content: center; }
  .hero-photo-wrap { width: 220px; height: 220px; margin: 0 auto; }
  .hero-photo-ring { width: 220px; height: 220px; }
}

@media (max-width: 480px) {
  .hero-ctas { flex-direction: column; align-items: center; }
}
</style>
