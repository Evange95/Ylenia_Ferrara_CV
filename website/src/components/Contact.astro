---
import { t, type Lang } from '../i18n/index.ts';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const tr = t(lang);
const ct = tr.contact;
const base = import.meta.env.BASE_URL;
---
<section id="contact">
  <div class="container">
    <p class="section-label" style="color:var(--violet-light)">{ct.label}</p>
    <h2 class="contact-title">{ct.title}</h2>
    <p class="contact-sub">{ct.sub}</p>

    <div class="contact-ctas">
      <a class="btn btn-light" href="mailto:yleferrara96@gmail.com">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        yleferrara96@gmail.com
      </a>
      <a class="btn btn-ghost" href="https://www.linkedin.com/in/yleniaferrara" target="_blank" rel="noopener">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
        LinkedIn
      </a>
      <a class="btn btn-ghost" href="https://medium.com/@yleniaferrara" target="_blank" rel="noopener">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M13.54 12a6.8 6.8 0 0 1-6.77 6.82A6.8 6.8 0 0 1 0 12a6.8 6.8 0 0 1 6.77-6.82A6.8 6.8 0 0 1 13.54 12zm7.42 0c0 3.54-1.51 6.42-3.38 6.42-1.87 0-3.39-2.88-3.39-6.42s1.52-6.42 3.39-6.42 3.38 2.88 3.38 6.42M24 12c0 3.17-.53 5.75-1.19 5.75-.66 0-1.19-2.58-1.19-5.75s.53-5.75 1.19-5.75C23.47 6.25 24 8.83 24 12z"/></svg>
        Medium
      </a>
    </div>

    <div class="contact-divider"></div>

    <div class="contact-cv">
      <p>{ct.cvLabel}</p>
      <a href={`${base}${tr.cvFile}`} download class="cv-btn">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        {tr.cvFile === 'cv.pdf' ? 'CV in English' : 'CV in Italiano'}
      </a>
    </div>

    <p class="contact-footer">{ct.footer}</p>
  </div>
</section>

<style>
#contact {
  background: var(--dark);
  padding: 5rem 0 4rem;
  text-align: center;
}

.contact-title {
  font-family: var(--font-display);
  font-size: clamp(2.5rem, 5vw, 4rem);
  color: var(--white);
  margin-bottom: 1rem;
}

.contact-sub {
  color: rgba(255,255,255,0.55);
  font-size: 1.05rem;
  max-width: 500px;
  margin: 0 auto 2.5rem;
  line-height: 1.6;
}

.contact-ctas {
  display: flex;
  gap: 1rem;
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: 3rem;
}

.btn-light {
  background: var(--white);
  color: var(--dark);
  border-color: var(--white);
}
.btn-light:hover {
  background: var(--violet-pale);
  border-color: var(--violet-pale);
  transform: translateY(-1px);
}

.btn-ghost {
  background: transparent;
  color: rgba(255,255,255,0.75);
  border-color: rgba(255,255,255,0.25);
}
.btn-ghost:hover {
  background: rgba(255,255,255,0.08);
  color: var(--white);
  border-color: rgba(255,255,255,0.5);
  transform: translateY(-1px);
}

.contact-divider {
  width: 60px;
  height: 1px;
  background: rgba(255,255,255,0.15);
  margin: 0 auto 2.5rem;
}

.contact-cv p {
  color: rgba(255,255,255,0.45);
  font-size: 0.82rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin-bottom: 1rem;
}

.cv-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.5rem 1.1rem;
  border: 1px solid rgba(255,255,255,0.2);
  border-radius: 1rem;
  font-size: 0.85rem;
  font-weight: 500;
  color: rgba(255,255,255,0.7);
  transition: all 0.2s;
}
.cv-btn:hover {
  background: rgba(255,255,255,0.08);
  color: var(--white);
  border-color: rgba(255,255,255,0.4);
}

.contact-footer {
  margin-top: 3rem;
  font-size: 0.8rem;
  color: rgba(255,255,255,0.3);
  letter-spacing: 0.05em;
}
</style>
