---
import { t, type Lang } from '../i18n/index.ts';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const tr = t(lang);
const ed = tr.education;
---
<section id="education" class="section">
  <div class="container">
    <p class="section-label">{ed.label}</p>
    <h2 class="section-title">{ed.title}</h2>
    <div class="edu-grid">
      {ed.degrees.map((d, i) => (
        <div class="edu-card card fade-in" style={`transition-delay:${i * 0.15}s`}>
          <div class="edu-period">{d.period}</div>
          <h3 class="edu-degree">{d.degree}</h3>
          <p class="edu-institution">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            {d.institution} · {d.location}
          </p>
          <p class="edu-thesis">
            <em>{ed.thesisLabel}:</em> {d.thesis}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
.edu-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5rem;
}

.edu-card {
  position: relative;
  border-top: 3px solid var(--violet);
}

.edu-period {
  font-size: 0.8rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--violet);
  margin-bottom: 0.75rem;
}

.edu-degree {
  font-family: var(--font-display);
  font-size: 1.2rem;
  font-weight: 600;
  color: var(--dark);
  margin-bottom: 0.5rem;
  line-height: 1.3;
}

.edu-institution {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.88rem;
  font-weight: 500;
  color: var(--muted);
  margin-bottom: 1rem;
}
.edu-institution svg { flex-shrink: 0; }

.edu-thesis {
  font-size: 0.85rem;
  color: var(--body);
  line-height: 1.55;
  border-left: 2px solid var(--border);
  padding-left: 0.75rem;
}
.edu-thesis em {
  font-style: italic;
  color: var(--muted);
}

@media (max-width: 700px) {
  .edu-grid { grid-template-columns: 1fr; }
}
</style>
