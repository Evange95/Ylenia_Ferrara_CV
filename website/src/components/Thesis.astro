---
import { t, type Lang } from '../i18n/index.ts';
import thesesData from '../content/theses.json';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const tr = t(lang);

const theses = thesesData.items;
---
<section id="thesis" class="section">
  <div class="container">
    <p class="section-label">{tr.thesis.label}</p>
    <h2 class="section-title">{tr.thesis.title}</h2>

    <div class="thesis-stack">
      {theses.map((t, i) => (
        <div class="thesis-item fade-in" style={`transition-delay:${i * 0.15}s`}>
          <div class="thesis-quote-bar"></div>
          <div class="thesis-body">
            <div class="thesis-meta">
              <span class="thesis-level">{t.level}</span>
              <span class="thesis-year">{t.year}</span>
              <span class="thesis-institution">
                {t.institution} · {t.degree}
              </span>
            </div>
            <blockquote class="thesis-title">{t.title}</blockquote>
            <p class="thesis-abstract">{t.abstract}</p>
            <div class="thesis-keywords">
              {t.keywords.map(k => <span class="tag">{k}</span>)}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
#thesis { background: var(--violet-pale); }

.thesis-stack {
  display: flex;
  flex-direction: column;
  gap: 2.5rem;
}

.thesis-item {
  display: flex;
  gap: 1.5rem;
}

.thesis-quote-bar {
  width: 3px;
  flex-shrink: 0;
  border-radius: 2px;
  background: linear-gradient(to bottom, var(--violet), var(--violet-light));
}

.thesis-body {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.thesis-meta {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  flex-wrap: wrap;
}

.thesis-level {
  font-size: 0.72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--white);
  background: var(--violet);
  padding: 0.15rem 0.55rem;
  border-radius: 0.5rem;
}

.thesis-year {
  font-size: 0.8rem;
  font-weight: 600;
  color: var(--muted);
}

.thesis-institution {
  font-size: 0.82rem;
  color: var(--muted);
  font-weight: 500;
}

.thesis-title {
  font-family: var(--font-display);
  font-size: 1.25rem;
  font-weight: 600;
  color: var(--dark);
  line-height: 1.4;
  font-style: italic;
}

.thesis-abstract {
  font-size: 0.9rem;
  color: var(--body);
  line-height: 1.7;
  max-width: 700px;
}

.thesis-keywords {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
}

@media (max-width: 600px) {
  .thesis-item { gap: 1rem; }
}
</style>
