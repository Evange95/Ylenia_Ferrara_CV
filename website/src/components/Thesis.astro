---
import { t, type Lang } from '../i18n/index.ts';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const tr = t(lang);

const theses = [
  {
    level: "Master's Thesis",
    degree: 'M.Sc in Strategic Communication',
    institution: 'IULM University, Milan',
    year: '2022',
    title: 'Public Affair solutions to facilitate the adoption of sustainable fishing methods in the Italian seas',
    abstract: 'Addresses sustainable ocean exploitation through the UN Agenda 2030 framework, examining Italy\'s position on sustainable fishing and the measures adopted to tackle by-catches. Uses a top-down approach from European to Italian policy, including a survey of 30 Sicilian fishermen. Proposes a dual communication strategy targeting public awareness and fisherman coordination for effective policy influence.',
    keywords: ['Public Affairs', 'Sustainability', 'CSR', 'Policy Communication', 'UN Agenda 2030'],
  },
  {
    level: "Bachelor's Thesis",
    degree: 'B.Sc in Modern Languages and Cultures',
    institution: 'KORE University, Enna',
    year: '2019',
    title: 'The condition of women in Islam: the cases of Morocco, Saudi Arabia, and Afghanistan',
    abstract: 'Analyzes the emergence and development of Islamic feminism across three nations through four chapters: pre-Islamic tribal culture and the Nahda period; Morocco\'s Pink Revolution and the Mudawwanat family code reforms; the evolution of women\'s rights in Saudi Arabia; and women\'s associations operating under fundamentalist pressures in Afghanistan.',
    keywords: ['Gender Studies', 'Islamic Feminism', 'Comparative Policy', 'Human Rights', 'MENA Region'],
  },
];
---
<section id="thesis" class="section">
  <div class="container">
    <p class="section-label">{tr.thesis.label}</p>
    <h2 class="section-title">{tr.thesis.title}</h2>

    <div class="thesis-grid">
      {theses.map((t, i) => (
        <div class="thesis-card card fade-in" style={`transition-delay:${i * 0.15}s`}>
          <div class="thesis-meta">
            <span class="thesis-level">{t.level}</span>
            <span class="thesis-year">{t.year}</span>
          </div>
          <h3 class="thesis-title">"{t.title}"</h3>
          <p class="thesis-institution">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            {t.institution} · {t.degree}
          </p>
          <p class="thesis-abstract">{t.abstract}</p>
          <div class="thesis-keywords">
            {t.keywords.map(k => <span class="tag">{k}</span>)}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
#thesis { background: var(--violet-pale); }

.thesis-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.75rem;
}

.thesis-card {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  border-top: 3px solid var(--violet);
}

.thesis-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.thesis-level {
  font-size: 0.72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--violet);
}

.thesis-year {
  font-size: 0.8rem;
  font-weight: 600;
  color: var(--muted);
  background: var(--border);
  padding: 0.15rem 0.55rem;
  border-radius: 0.5rem;
}

.thesis-title {
  font-family: var(--font-display);
  font-size: 1.05rem;
  font-weight: 600;
  color: var(--dark);
  line-height: 1.4;
  font-style: italic;
}

.thesis-institution {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.82rem;
  color: var(--muted);
  font-weight: 500;
}
.thesis-institution svg { flex-shrink: 0; }

.thesis-abstract {
  font-size: 0.88rem;
  color: var(--body);
  line-height: 1.65;
  flex: 1;
}

.thesis-keywords {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
}

@media (max-width: 768px) {
  .thesis-grid { grid-template-columns: 1fr; }
}
</style>
