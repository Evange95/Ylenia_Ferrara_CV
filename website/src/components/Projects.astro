---
import { t, type Lang } from '../i18n/index.ts';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const tr = t(lang);

const projects = tr.projectsData;
---
<section id="projects" class="section">
  <div class="container">
    <p class="section-label">{tr.projects.label}</p>
    <h2 class="section-title">{tr.projects.title}</h2>
    <p class="projects-intro">{projects.intro}</p>

    <div class="projects-grid">
      {projects.items.map((p: { company: string; course: string; description: string; tags: string[]; pdf?: string }, i: number) => (
        <div class="project-card card fade-in" style={`transition-delay:${(i % 4) * 0.08}s`}>
          <div class="project-header">
            <span class="project-course">{p.course}</span>
          </div>
          <h3 class="project-company">
            {p.pdf
              ? <a href={p.pdf} target="_blank" rel="noopener noreferrer">{p.company}</a>
              : p.company}
          </h3>
          <p class="project-description">{p.description}</p>
          <div class="project-tags">
            {p.tags.map((tag: string) => <span class="tag">{tag}</span>)}
          </div>
        </div>
      ))}
    </div>

    <p class="projects-disclaimer">{projects.disclaimer}</p>
  </div>
</section>

<style>
#projects { background: var(--white); }

.projects-intro {
  color: var(--muted);
  font-size: 1rem;
  margin-top: -1.5rem;
  margin-bottom: 2.5rem;
  max-width: 680px;
}

.projects-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.25rem;
}

.project-card {
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
}

.project-header {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.project-course {
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--violet);
  background: var(--violet-light);
  padding: 0.2rem 0.6rem;
  border-radius: 0.5rem;
}

.project-company {
  font-family: var(--font-display);
  font-size: 1rem;
  font-weight: 600;
  color: var(--dark);
  line-height: 1.25;
}
.project-company a {
  color: inherit;
  text-decoration: none;
  border-bottom: 1.5px solid var(--violet-light);
  transition: border-color 0.2s, color 0.2s;
}
.project-company a:hover {
  color: var(--violet);
  border-color: var(--violet);
}

.project-description {
  font-size: 0.85rem;
  color: var(--muted);
  line-height: 1.6;
  flex: 1;
}

.project-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.3rem;
  margin-top: auto;
}
.project-tags .tag {
  font-size: 0.72rem;
  padding: 0.15rem 0.55rem;
}

.projects-disclaimer {
  margin-top: 2.5rem;
  font-size: 0.75rem;
  color: var(--muted);
  line-height: 1.6;
  max-width: 680px;
  opacity: 0.7;
}

@media (max-width: 768px) {
  .projects-grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 500px) {
  .projects-grid { grid-template-columns: 1fr; }
}
</style>
